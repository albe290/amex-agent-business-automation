# Environment Configuration — Example
# Copy this to .env and fill in real values before starting the platform.
# Never commit .env to source control.

# =============================================================================
# CORE AI / LLM
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# =============================================================================
# API SERVICE
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true                        # Set to false in production
API_WORKERS=1                          # Increase for production

# =============================================================================
# DASHBOARD SERVICE
# =============================================================================
DASHBOARD_PORT=5173                    # Vite dev server; 80 in Docker prod
DASHBOARD_API_BASE_URL=http://localhost:8000

# =============================================================================
# EVENT PIPELINE
# =============================================================================
QUEUE_MODE=memory                      # memory | kafka | sqs
QUEUE_MAX_DEPTH=500
CONSUMER_POLL_INTERVAL_MS=250
CONSUMER_BATCH_SIZE=1

# Kafka settings (only used when QUEUE_MODE=kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INCOMING=platform.events.incoming
KAFKA_TOPIC_OUTCOMES=platform.events.outcomes
KAFKA_CONSUMER_GROUP=governed-platform-workers

# =============================================================================
# STORAGE / PERSISTENCE
# =============================================================================
STORAGE_MODE=memory                    # memory | file | postgres
AUDIT_LOG_PATH=./logs/audit.jsonl
EVAL_RESULTS_PATH=./logs/evals.json

# PostgreSQL (only used when STORAGE_MODE=postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/amex_platform

# =============================================================================
# RISK ENGINE THRESHOLDS
# =============================================================================
RISK_THRESHOLD_AUTOMATE=20.0
RISK_THRESHOLD_ESCALATE=70.0
MISSING_CONTEXT_PENALTY=25.0
UNKNOWN_MERCHANT_PENALTY=15.0

# =============================================================================
# RUNTIME GOVERNANCE
# =============================================================================
MAX_AGENT_STEPS=10
MAX_RETRIES=3
BUDGET_MAX_TOKENS=4000
FALLBACK_ON_BUDGET_EXCEEDED=true

# =============================================================================
# SECURITY
# =============================================================================
SENTINEL_ENABLED=true
OUTPUT_SCAN_ENABLED=true
PII_DETECTION_ENABLED=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_LIVE_AGENTS=false              # true = use real CrewAI; false = mock
FEATURE_REVIEW_QUEUE=true
FEATURE_EVALS=true
FEATURE_DASHBOARD_REALTIME=true
